# Copy to .env. The Django API base (reachable during SSR and from the browser).
NUXT_PUBLIC_API_BASE=http://localhost:8000
# Public canonical site URL (used for SEO meta, sitemap, robots).
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: enable dynamic Unsplash image search (server-side only).
# Get a key at https://unsplash.com/developers — without it, the curated image set is used.
NUXT_UNSPLASH_ACCESS_KEY=
