# Copy to .env and fill in. Never commit .env.
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (local). For first boot you may use sqlite by leaving DATABASE_URL unset in dev.
DATABASE_URL=postgres://booksall:booksall@localhost:5432/booksall

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# CORS (your Nuxt dev origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email (console backend in dev by default)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@booksall.com

# Frontend base used to build verification / reset links
FRONTEND_URL=http://localhost:3000

# Password reset / email verification token lifetime (seconds). 1800 = 30 min.
PASSWORD_RESET_TIMEOUT=1800

# Sentry (leave blank to disable)
SENTRY_DSN=
